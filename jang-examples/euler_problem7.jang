
fn is_prime(n: i64): bool {
  let true = 0 == 0
  let false = 0 == 1

  mut i = 2
  loop {
    if i * i > n {
      ret true
    } else if n % i == 0 {
      ret false
    }

    i = i + 1
  }
}

fn nth_prime(n: i64): i64 {
  mut num_primes = 0
  mut i = 2
  loop {
    if is_prime(i) {
      num_primes = num_primes + 1

      if num_primes == n {
        ret i
      }
    }
    i = i + 1
  }
}

fn main(): i64 {
  ret nth_prime(10001)
}
